# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# --- Models / API ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
LOCAL_MODEL=qwen3:30b-a3b
LOCAL_MODEL_FAST=qwen3:8b
LOCAL_MODEL_TINY=qwen3:4b
VISION_MODEL=moondream
EMBED_MODEL=all-minilm
WHISPER_MODEL=base.en

# --- Tapo C236 network camera (RTSP capture) ---
TAPO_CAMERA_HOST=10.0.0.65
TAPO_CAMERA_PORT=554
TAPO_CAMERA_USERNAME=
TAPO_CAMERA_PASSWORD=
TAPO_CAMERA_STREAM=stream1
TAPO_CAMERA_NAME=office
TAPO_CAMERA_CAPTURE_DIR=artifacts/camera

# --- Optional: ONVIF pan/tilt (PTZ). Off by default. ---
# The ONVIF service port is NOT the RTSP port (554). Requires: pip install onvif-zeep
# For Tapo C236, ONVIF is commonly on port 2020 — confirm with a read-only probe first.
TAPO_ONVIF_ENABLED=false
TAPO_ONVIF_PORT=2020
TAPO_ONVIF_USERNAME=
TAPO_ONVIF_PASSWORD=
